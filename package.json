{
  "name": "latoile",
  "version": "0.1.0",
  "description": "Live context bridge: from a single Jira task, recursively fetch the Jira context graph, enrich it with GitLab data, expose it through a live backend API and visualize it.",
  "type": "module",
  "main": "dist/src/api/server.js",
  "bin": {
    "latoile": "dist/src/cli.js",
    "latoile-mcp": "dist/src/mcp/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.web.json",
    "build:server": "tsc -p tsconfig.json",
    "build:web": "tsc -p tsconfig.web.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "lint": "eslint .",
    "prestart": "tsc -p tsconfig.json",
    "start": "node dist/src/api/server.js",
    "pregraph": "tsc -p tsconfig.json",
    "graph": "node dist/src/cli.js",
    "pretest": "tsc -p tsconfig.json",
    "test": "node --test dist/test/*.test.js",
    "premcp": "tsc -p tsconfig.json",
    "mcp": "node dist/src/mcp/server.js"
  },
  "engines": {
    "node": ">=22.13"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.19.2",
    "neo4j-driver": "^6.2.0",
    "zod": "^4.4.3"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^4.17.25",
    "@types/node": "^26.1.1",
    "eslint": "^10.6.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.63.0"
  }
}
